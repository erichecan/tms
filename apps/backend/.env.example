# TMS 后端环境变量配置模板
# 复制此文件为 .env 并填入实际值

# 数据库连接 URL (Neon PostgreSQL)
# 格式: postgresql://用户名:密码@主机/数据库名?sslmode=require
DATABASE_URL="postgresql://neondb_owner:YOUR_PASSWORD@YOUR_HOST/neondb?sslmode=require"

# 后端服务端口
PORT=3001

# Google Maps API 密钥
GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY

# JWT 密钥（必填，用于用户认证）
# 生成方式: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=YOUR_STRONG_RANDOM_SECRET_HERE

# CORS 允许的源（生产环境应填写实际前端域名）
CORS_ORIGIN=https://your-frontend-domain.run.app
