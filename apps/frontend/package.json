{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test:e2e": "playwright test",
    "test:e2e:tms": "playwright test e2e/tms-full-suite.spec.ts",
    "test:e2e:full": "playwright test e2e/full-flow-ui.spec.ts",
    "test:e2e:human:multi": "TMS_HUMAN_TYPING=1 playwright test e2e/multi-role-flow.spec.ts --project=chromium-human --workers=1 --timeout=120000",
    "test:e2e:human:full": "TMS_HUMAN_TYPING=1 TMS_E2E_REAL_API=1 playwright test e2e/full-flow-ui.spec.ts --project=chromium-human --workers=1 --timeout=120000"
  },
  "dependencies": {
    "i18next": "^25.7.4",
    "i18next-browser-languagedetector": "^8.2.0",
    "lru-cache": "^5.1.1",
    "lucide-react": "^0.562.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-i18next": "^16.5.1",
    "react-router-dom": "^7.12.0",
    "react-signature-canvas": "^1.1.0-alpha.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.57.0",
    "@types/google.maps": "^3.58.1",
    "@types/lru-cache": "^7.10.9",
    "@types/node": "^24.10.4",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@types/react-signature-canvas": "^1.0.7",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4"
  }
}
